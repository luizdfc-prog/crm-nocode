# Porta do servidor (Railway injeta automaticamente)
PORT=3001

# Secret compartilhado com o Z4P CRM para autenticar as requisições
BAILEYS_API_SECRET=troque-por-um-segredo-forte

# URL do webhook no Z4P que recebe mensagens do WhatsApp
# Ex: https://seu-app.vercel.app/api/webhooks/whatsapp-qr
Z4P_WEBHOOK_URL=

# ID do workspace dono deste número
WORKSPACE_ID=
